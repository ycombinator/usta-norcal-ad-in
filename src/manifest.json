{
  "manifest_version": 3,
  "name": "USTA NorCal Ad In",
  "version": "0.2.1",
  "description": "Enhance USTA NorCal UIs with information and functionality",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.tennisrecord.com/*",
    "https://api.utrsports.net/*",
    "https://app.utrsports.net/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://leagues.ustanorcal.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}